{
    "name": "neolesk",
    "version": "2.0.0",
    "private": true,
    "homepage": "https://neolesk.pages.dev",
    "dependencies": {
        "@monaco-editor/react": "^4.7.0",
        "@softwaretechnik/dbml-renderer": "^1.0.31",
        "@testing-library/jest-dom": "^5.16.1",
        "@testing-library/react": "^12.1.2",
        "bytefield-svg": "^1.11.0",
        "canvg": "^4.0.3",
        "jspdf": "^4.2.0",
        "mermaid": "^11.12.3",
        "monaco-editor": "^0.52.2",
        "nomnoml": "^1.7.0",
        "onml": "^2.1.0",
        "pako": "^2.0.4",
        "react": "^17.0.2",
        "react-dom": "^17.0.2",
        "react-zoom-pan-pinch": "^3.0.7",
        "vega": "^6.2.0",
        "vega-lite": "^6.4.1",
        "wavedrom": "^3.5.0",
        "yaml": "^2.8.2"
    },
    "scripts": {
        "examples:cache": "node scripts/generate-example-cache.cjs",
        "prestart": "npm run examples:cache",
        "start": "vite",
        "build": "vite build",
        "prepreview": "npm run examples:cache",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "prebuild": "npm run examples:cache",
        "predeploy": "npm run build",
        "deploy": "wrangler pages deploy dist --project-name neolesk",
        "dev": "skaffold dev -n kroki --cleanup=false",
        "deploy:k8s": "skaffold run -n kroki --cleanup=false"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@types/react": "^17.0.89",
        "@types/react-dom": "^17.0.26",
        "@vitejs/plugin-react": "^5.0.0",
        "jsdom": "^26.0.0",
        "knip": "^5.86.0",
        "playwright": "^1.58.2",
        "typescript": "^5.8.2",
        "vite": "^6.2.0",
        "vitest": "^3.0.8",
        "wrangler": "^4.0.0"
    }
}
